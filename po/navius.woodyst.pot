msgid "Saltar tour"
msgstr ""

#: qml/TourOverlay.qml:316
msgid "Atrás"
msgstr ""

#: qml/TourOverlay.qml:339
msgid "Gestionar voces"
msgstr ""

#: qml/TourOverlay.qml:340
