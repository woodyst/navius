msgid "No mostrar al inicio"
msgstr "Don't show at startup"

#: qml/TourOverlay.qml:315
msgid "Saltar tour"
msgstr "Skip tour"

#: qml/TourOverlay.qml:316
msgid "Atrás"
msgstr "Back"

