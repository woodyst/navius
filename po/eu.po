"Genera un enlace para que otros puedan seguir tu posición y ruta en tiempo "
"real desde cualquier navegador."
msgstr ""
"Sortu esteka bat, beste batzuek zure kokapena eta ibilbidea denbora "
"errealean edozein nabigatzailetik jarrai dezaten."

#: qml/TripSharePanel.qml:111
msgid "✓ Copiado"
msgstr "✓ Kopiatuta"

#: qml/TripSharePanel.qml:111
msgid "Copiar"
msgstr "Kopiatu"

#: qml/TripSharePanel.qml:147
#, fuzzy
msgid "Generando…"
msgstr "Sortzen…"

#: qml/TripSharePanel.qml:148
#, fuzzy
msgid "Abrir en navegador"
msgstr "Nabigatzailean ireki"

#: qml/TripSharePanel.qml:149
#, fuzzy
msgid "Crear enlace"
msgstr "Esteka sortu"

#: qml/TripSharePanel.qml:172
