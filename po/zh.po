#: qml/AlertasOverlay.qml:410 qml/LoginPanel.qml:345
#: qml/PreferencesPanel.qml:419 qml/PreferencesPanel.qml:931
#: qml/PreferencesPanel.qml:2179
msgid "Cancelar"
msgstr "取消"

#: qml/WhatsNewDialog.qml:22
msgid ""
"Búsqueda de puntos de interés cerca de ti: gasolineras, parking, "
"restaurantes, hoteles y más"
msgstr "搜索附近兴趣点：加油站、停车场、餐厅、酒店等"

#: qml/WhatsNewDialog.qml:23
